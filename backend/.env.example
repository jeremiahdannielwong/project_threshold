# Copy to .env and fill in. Never commit .env.

# Local cache directory for the pipeline's upstream zip / CSV downloads.
# The backend does NOT read from here — Postgres is the system of record.
# Defaults to <repo>/pipeline/data.
THRESHOLD_DATA_DIR=

# CORS origins (comma-separated). Defaults to localhost dev origins.
THRESHOLD_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Alectra live outage feed (ArcGIS REST endpoint, layer 7 = Outage Area polygons).
THRESHOLD_ALECTRA_OUTAGES_URL=https://services8.arcgis.com/wNDmObY7QplwZD9m/ArcGIS/rest/services/Outage_Details/FeatureServer/7/query

# Open-Meteo current-conditions endpoint.
THRESHOLD_OPENMETEO_URL=https://api.open-meteo.com/v1/forecast

# TTL (seconds) for live data caches.
THRESHOLD_OUTAGES_TTL=300
THRESHOLD_WEATHER_TTL=900

# Postgres connection string. REQUIRED for the pipeline (`python -m app.pipeline`)
# and for the backend to serve any community data — the ontology lives in DB.
# When unset, the backend still boots with an empty store and a warning.
# Example: postgresql+asyncpg://user:pass@host:5432/dbname
THRESHOLD_DATABASE_URL=

# OpenWeather (used for live Brampton grid fetches).
OPENWEATHER_API_KEY=

# Optional. If set, /api/briefing calls Gemini; otherwise the route returns a
# deterministic fallback briefing built from the numeric inputs.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=10
